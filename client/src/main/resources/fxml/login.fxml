<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.auction.controller.LoginController"
      alignment="CENTER" spacing="14" styleClass="root-pane">
    <padding><Insets topRightBottomLeft="48"/></padding>

    <Text text="Auction Platform" styleClass="title"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="260"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="260"/>

    <Button text="Login" onAction="#onLogin" styleClass="btn-primary" prefWidth="260"/>

    <Separator maxWidth="260"/>

    <Label text="Don't have an account?" styleClass="muted-label"/>
    <Button text="Register" onAction="#onGoToRegister" styleClass="btn-secondary" prefWidth="260"/>
    <Button text="Server" onAction="#onConfigureServer" styleClass="btn-secondary" prefWidth="260"/>

    <Label alignment="CENTER" fx:id="errorLabel" styleClass="error-label" wrapText="true" maxWidth="300"/>
</VBox>
