<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.auction.controller.RegisterController"
      alignment="CENTER" spacing="14" styleClass="root-pane">
    <padding><Insets topRightBottomLeft="40"/></padding>

    <Text text="Create Account" styleClass="title"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="260"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="260"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="260"/>

    <HBox alignment="CENTER" spacing="20">
        <Label text="Register as:"/>
        <fx:define><ToggleGroup fx:id="roleGroup"/></fx:define>
        <RadioButton fx:id="bidderRadio" text="Bidder" toggleGroup="$roleGroup"/>
        <RadioButton fx:id="sellerRadio" text="Seller" toggleGroup="$roleGroup"/>
    </HBox>

    <Button text="Create Account" onAction="#onRegister" styleClass="btn-primary" prefWidth="260"/>

    <Separator maxWidth="260"/>

    <Label text="Already have an account?" styleClass="muted-label"/>
    <Button text="Back to Login" onAction="#onBackToLogin" styleClass="btn-secondary" prefWidth="260"/>

    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" maxWidth="300"/>
</VBox>
